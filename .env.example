# Copier ce fichier en .env et renseigner les valeurs

# Base de données
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/assistant_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_db_password
SPRING_JPA_HIBERNATE_DDL_AUTO=update

POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=assistant_db

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_EXPIRATION=86400000

# Email (SMTP)
APP_EMAIL_HOST=smtp.gmail.com
APP_EMAIL_PORT=587
APP_EMAIL_USERNAME=your_email@gmail.com
APP_EMAIL_PASSWORD=your_app_password
APP_EMAIL_FROM=your_email@gmail.com

# Frontend
APP_FRONTEND_URL=http://localhost:3100,http://localhost:5173

# Upload
APP_UPLOAD_DIR=./uploads

# IA / LLM (OpenAI-compatible)
APP_SEMANTIC_EXTRACTOR_ENABLED=true
APP_SEMANTIC_EXTRACTOR_BASE_URL=https://api.openai.com
APP_SEMANTIC_EXTRACTOR_API_KEY=sk-your_openai_api_key
APP_SEMANTIC_EXTRACTOR_MODEL=gpt-4o-mini
